SECRET_KEY=replace-with-long-random-secret
DEBUG=False
ALLOWED_HOSTS=your-app-domain.example.com
CSRF_TRUSTED_ORIGINS=https://your-app-domain.example.com

DB_ENGINE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mpted
DB_USER=postgres
DB_PASSWORD=replace-with-db-password

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=replace-with-strong-password
DJANGO_SUPERUSER_UPDATE_PASSWORD=False

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your_email@example.com
SERVER_EMAIL=your_email@example.com

BREVO_API_KEY=
EMAIL_SENDER_NAME=MPTed
